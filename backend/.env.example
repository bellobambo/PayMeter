NODE_ENV=development
PORT=5000

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-secret-key

# Nomba - use TEST/Sandbox values during development
NOMBA_BASE_URL=https://sandbox.nomba.com
NOMBA_CLIENT_ID=your-test-client-id
NOMBA_CLIENT_SECRET=your-test-client-secret-or-private-key
NOMBA_PARENT_ACCOUNT_ID=your-parent-account-id
NOMBA_SUB_ACCOUNT_ID=your-team-sub-account-id

# Needed from webhook implementation onward
NOMBA_WEBHOOK_SECRET=your-nomba-webhook-signature-key
