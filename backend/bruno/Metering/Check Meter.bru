}

body:json {
  {
    "userId": "{{customerUserId}}",
    "featureName": "{{featureName}}",
    "founderId": "{{founderId}}"
  }
}

tests {
  test("should execute entitlement check", function() {
    expect([200, 402]).to.include(res.status);
  });
}
