meta {
  name: Initiate Bank Transfer
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/api/nomba/transfers/bank
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "amount": 1000,
    "accountNumber": "replace-with-recipient-account-number",
    "accountName": "replace-with-account-name-from-lookup",
    "bankCode": "305",
    "merchantTxRef": "paymeter-transfer-001",
    "senderName": "PayMeter",
    "narration": "PayMeter payout"
  }
}
