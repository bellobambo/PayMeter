meta {
  name: Create Virtual Account
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/nomba/virtual-accounts
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "userId": "test_user_001",
    "name": "John Doe",
    "email": "john.doe@example.com",
    // optional
    "companyName": "Acme Labs",
    // optional
    "phoneNumber": "+2348012345678"
  }
}
