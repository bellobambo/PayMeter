meta {
  name: List API Keys
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/founders/api-keys
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{token}}
}

tests {
  test("should list API keys successfully", function() {
    expect(res.status).to.equal(200);
    expect(res.body.success).to.be.true;
    expect(res.body.data).to.be.an('array');
  });
}
