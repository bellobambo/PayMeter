meta {
  name: Delete API Key
  type: http
  seq: 3
}

delete {
  url: {{baseUrl}}/api/founders/api-keys/{{apiKeyId}}
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{token}}
}

tests {
  test("should delete API key successfully", function() {
    expect(res.status).to.equal(200);
    expect(res.body.success).to.be.true;
  });
}
